{
  "name": "grocery-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "web": "expo start --web",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview --platform all",
    "eas:build:production": "eas build --profile production --platform all",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android --profile production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "expo": "~55.0.17",
    "expo-auth-session": "^55.0.15",
    "expo-constants": "^55.0.15",
    "expo-dev-client": "^55.0.28",
    "expo-linking": "^55.0.14",
    "expo-router": "^55.0.13",
    "expo-secure-store": "^55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "^55.0.14",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@react-native-async-storage/expo-with-async-storage": "^1.0.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "^55.0.17",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "pnpm@10.18.3"
}
