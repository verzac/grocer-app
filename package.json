{
  "name": "grocery-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "web": "expo start --web",
    "eas:update": "pnpm eas:update:production",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview --platform all",
    "eas:build:production": "eas build --profile production --platform all",
    "eas:update:development": "eas update --channel development --environment development",
    "eas:update:preview": "eas update --channel preview --environment preview",
    "eas:update:production": "eas update --channel production --environment production",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android --profile production",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:paths": "prettier --write",
    "format:check:paths": "prettier --check"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-vector-icons/ionicons": "^13.1.2",
    "expo": "~56.0.12",
    "expo-auth-session": "^56.0.14",
    "expo-background-task": "~56.0.19",
    "expo-constants": "^56.0.18",
    "expo-dev-client": "^56.0.20",
    "expo-linking": "^56.0.14",
    "expo-router": "^56.2.11",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "^56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "0.8.3",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@react-native-async-storage/expo-with-async-storage": "^1.0.0",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "^56.0.15",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "pnpm@10.18.3"
}
